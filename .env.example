# Postgres connection string — use a French-hosted instance (Scaleway/OVHcloud)
# even for local dev if you want to test the data-residency story end to end.
DATABASE_URL="postgresql://user:password@localhost:5432/conforma?schema=public"

# Auth (NextAuth) — placeholder until the real provider (Keycloak, per spec §3) is wired in
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-string"

# Mailbox integration (spec §5.11) — not needed to run Phase 1 core, only
# once the mailbox connection feature is implemented. Create a Google Cloud
# OAuth client (Web application) with redirect URI
# {origin}/api/auth/callback/google — see README for the full walkthrough.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Encrypts MailboxConnection's stored OAuth tokens at rest (AES-256-GCM) —
# 32 random bytes, base64. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=""

# AI — platform-level, not per-organization (see src/lib/ai.ts): one key,
# billed to Conforma, powers "Assister avec l'IA" and "Extraire avec l'IA"
# for every tenant. Get one at platform.openai.com (API keys, separate from
# a personal ChatGPT Plus subscription — needs its own billing set up).
OPENAI_API_KEY=""

# Transactional email — platform-level too (see src/lib/brevo.ts): one
# Brevo account sends for every tenant (Team invites, convocations,
# positioning test, contract, platform access). BREVO_SENDER_EMAIL must be
# a domain verified in your Brevo account (Senders & IP > Domains) — the
# recipient still sees the organization's own name as the sender name.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""

# E-signature (spec §3)
YOUSIGN_API_KEY=""

# E-invoicing connector (spec §5.3 / §7.2) — client chooses their own provider,
# so these are per-tenant credentials in the real app, not global env vars.
# Left here only as a placeholder for local testing against one sandbox account.
PENNYLANE_API_KEY=""
