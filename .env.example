# Postgres connection string — use a French-hosted instance (Scaleway/OVHcloud)
# even for local dev if you want to test the data-residency story end to end.
DATABASE_URL="postgresql://user:password@localhost:5432/conforma?schema=public"

# Auth (NextAuth) — placeholder until the real provider (Keycloak, per spec §3) is wired in
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-string"

# Mailbox integration (spec §5.11) — not needed to run Phase 1 core, only
# once the mailbox connection feature is implemented
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# E-signature (spec §3)
YOUSIGN_API_KEY=""

# E-invoicing connector (spec §5.3 / §7.2) — client chooses their own provider,
# so these are per-tenant credentials in the real app, not global env vars.
# Left here only as a placeholder for local testing against one sandbox account.
PENNYLANE_API_KEY=""
