// Conforma — Phase 1 data model
// Multi-tenancy strategy: shared schema, every tenant-scoped table carries
// an `organizationId` foreign key + index. Enforce isolation at the query
// layer (see src/lib/tenant.ts) until/unless Postgres RLS is added later —
// that decision is flagged as open in the spec (§10) and should be
// confirmed with the developer before this goes further.

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy, users, roles
// ---------------------------------------------------------------------------

model Organization {
  id            String    @id @default(cuid())
  name          String
  nextAuditDate DateTime?
  createdAt     DateTime  @default(now())

  // Billing identity for the ORGANIZATION'S OWN Conforma subscription —
  // the org is the paying customer, so this is what a real invoice from
  // Conforma to them would need (Stripe customer creation, French invoice
  // legal-mention requirements). Collected at signup (see /essai). Not to
  // be confused with the org's own Company/Contact records, which are
  // their end customers, a separate concern.
  siret               String?
  billingAddress      String?
  billingPostalCode   String?
  billingCity         String?

  // Legal identity mentions the OFP needs printed on documents it issues
  // to ITS OWN clients (contracts, conventions, CGV — the French "mentions
  // légales" block: forme juridique + capital social + siège social + RCS +
  // représentant légal). Distinct from the billing fields above, which are
  // about Conforma invoicing the org, not the org invoicing its clients.
  // Editable from /profil (ADMIN_OF only) and merged into templates via
  // mergeTemplate.ts's AVAILABLE_MERGE_FIELDS.
  legalForm               String?
  shareCapital            String?
  legalAddress            String?
  rcsCity                 String?
  rcsNumber               String?
  legalRepresentativeName String?

  users               User[]
  contacts            Contact[]
  companies           Company[]
  dossiers            Dossier[]
  opportunities       Opportunity[]
  courses             Course[]
  sessions            Session[]
  quotes              Quote[]
  invoices            Invoice[]
  payments            Payment[]
  processingActivities ProcessingActivity[]
  subProcessors       SubProcessor[]
  qualiopiIndicators  QualiopiIndicatorEvidence[]
  auditChecklistItems AuditChecklistItem[]
  dpiaRecords         DPIARecord[]
  sessionInvitations  SessionInvitation[]
  nonConformities     NonConformity[]
  rightsRequests      RightsRequest[]
  dataBreaches        DataBreach[]
  documents           Document[]
  documentTemplates   DocumentTemplate[]
  needsAssessmentRequests NeedsAssessmentRequest[]
  emailMessages       EmailMessage[]
  mailboxConnections  MailboxConnection[]
  integrationCredentials IntegrationCredential[]
  clientOutreaches    ClientOutreach[]
  subscription        Subscription?
  qualityRisks        QualityRisk[]
  resultIndicators    ResultIndicator[]
  dashboardTaskDismissals DashboardTaskDismissal[]
  orgChartSnapshots OrgChartSnapshot[]
  satisfactionSurveys SatisfactionSurvey[]
  satisfactionSurveyResponses SatisfactionSurveyResponse[]

  // Which version of the RNQ this org is currently auditing itself against
  // (see QualiopiReferentielVersion) — nullable only until the backfill
  // migration sets every existing org to the 2022 version; every org gets
  // one from creation onward in practice.
  activeReferentielVersion   QualiopiReferentielVersion? @relation("ActiveReferentiel", fields: [activeReferentielVersionId], references: [id])
  activeReferentielVersionId String?

  // The person designated as référent handicap (RNQ indicator 20) — not a
  // separate Role, since in practice this is a specific person on an
  // existing team (often a TRAINER or ADMIN_MANAGER) wearing an extra hat,
  // not a distinct job function needing its own permission tier. Access to
  // AccommodationRequest is gated on being this specific user (or an admin),
  // not on role alone — see canAccessAccommodations in src/lib/tenant.ts.
  referentHandicapUser   User?   @relation("ReferentHandicap", fields: [referentHandicapUserId], references: [id])
  referentHandicapUserId String?

  accommodationRequests AccommodationRequest[]
  complaints            Complaint[]
  secureReports         SecureReport[]
  regulatoryWatchItems  RegulatoryWatch[]
  subcontractors        Subcontractor[]
  automationRules       AutomationRule[]
}

// Confidential — situation de handicap is sensitive personal data under
// RGPD art. 9 (special category). description/requestedAccommodations are
// never shown to anyone outside canAccessAccommodations() (admins + the
// designated référent handicap), not even other staff with normal "dossiers"
// access. See RNQ indicators 13/16/20.
model AccommodationRequest {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  dossier        Dossier      @relation(fields: [dossierId], references: [id])
  dossierId      String

  description             String
  requestedAccommodations String
  status                  String    @default("pending") // pending | granted | declined
  grantedAccommodations   String?
  handledByUserId         String?
  handledByName           String?
  handledAt                DateTime?

  createdByName String
  createdAt     DateTime @default(now())

  @@index([organizationId])
  @@index([dossierId])
}

// A learner (or staff) complaint about a training — separate from
// EmailMessage/inbox (that's unstructured correspondence; this is a
// tracked complaint with a status workflow) and separate from
// NonConformity (which is Qualiopi reference data feeding the amélioration
// continue register — a resolved Complaint can become a NonConformity/risk
// input, but the two aren't the same record).
model Complaint {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  dossier        Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId      String?

  subject         String
  description     String
  submittedByName String
  // Captured at submission time from the (always-authenticated) submitter's
  // session — client feedback: staff need to find the complainant's email
  // straight from the request, not go hunting for their dossier/contact
  // record first. Clickable as a mailto: link in the UI.
  submittedByEmail String?
  // Which intent the unified support dialog's picker was set to — "complaint"
  // | "question" | "other" — purely for staff triage, same underlying model
  // and workflow either way.
  category        String    @default("other")
  status          String    @default("open") // open | investigating | resolved
  resolutionNotes String?
  resolvedAt      DateTime?

  // Client feedback: a request should be assignable to a specific staff
  // member with their own working note and a deadline, independent of the
  // open/investigating/resolved status — assignment is "whose job is this"
  // while status is "where is it at."
  assignedToUserId String?
  assignedToName   String?
  assigneeComment  String?
  assigneeDeadline DateTime?
  // Manual, independent of status — client feedback: a resolved complaint
  // shouldn't just pile up in the main list forever; give staff an explicit
  // "Archivées" tab to move it out of the way once truly done with it.
  archivedAt DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([dossierId])
}

// Deliberately separate from Complaint: a harassment/discrimination report
// needs a much smaller circle of people able to read it (see
// canAccessSecureReports in src/lib/tenant.ts — admins only, no "référent"
// carve-out like accommodations has, since the report could be about
// anyone including a référent). reporterName/reporterContact are optional
// — an anonymous report is still a valid report. SecureReportAccessLog
// gives the traceability the escalation procedure needs: every time an
// admin actually views a report, that's logged and visible to every admin,
// not hidden even from the viewer themselves.
model SecureReport {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  reporterName    String?
  reporterContact String?
  description     String
  status          String    @default("received") // received | under_review | escalated | closed
  escalationNotes String?
  escalatedAt     DateTime?

  // Same reasoning as Complaint above — "whose job is this" independent of
  // status, plus an explicit archive so a closed report doesn't linger in
  // the main confidential-channel list forever.
  assignedToUserId String?
  assignedToName   String?
  assigneeComment  String?
  assigneeDeadline DateTime?
  archivedAt       DateTime?

  createdAt DateTime @default(now())

  accessLog SecureReportAccessLog[]

  @@index([organizationId])
}

model SecureReportAccessLog {
  id             String       @id @default(cuid())
  report         SecureReport @relation(fields: [reportId], references: [id])
  reportId       String
  viewedByUserId String
  viewedByName   String
  viewedAt       DateTime     @default(now())

  @@index([reportId])
}

// RNQ indicators 22-25 ask for more than "we monitor X source" — an
// auditor wants to see a watch item actually turn into a decision and a
// concrete action, not sit as a logged link nobody acted on. status tracks
// that progression explicitly (identified → decided → exploited) rather
// than leaving it to be inferred from which optional fields are filled;
// exploitedAt is the field that answers "was this actually put into
// practice," which is the part a source-logging tool usually skips.
model RegulatoryWatch {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  watchType String // legal | metiers_competences | pedagogique_technologique | reseaux_partenariats
  source    String
  watchDate DateTime
  summary   String
  ownerName String

  decision     String?
  actionTaken  String?
  exploitedAt  DateTime?
  evidenceNote String?
  status       String @default("identified") // identified | decided | exploited

  affectedCourses Course[]

  createdByName String
  createdAt     DateTime @default(now())

  @@index([organizationId])
}

// A trainer/subcontractor delivering training on the org's behalf — the
// record the org keeps for Qualiopi indicator 17 (qualification of
// external/internal staff) and indicator 19 (coordination/supervision of
// intervenants), independent of whether they ever get a Conforma account.
// Documents (contract, diploma, insurance...) reuse the existing Document
// model via subcontractorId rather than a parallel table.
// Client feedback: a formateur_externe should be assignable to a session
// like any other trainer — rather than duplicating Session.trainerId to
// accept a Subcontractor too, `linkedUser` is the bridge: an admin can send
// a real platform invitation (same flow as inviting a staff member, see
// /api/team/invite) that creates a User row and links it back here. Once
// linked, they show up in every trainer picker exactly like a regular
// TRAINER — no separate "or a subcontractor" branching needed anywhere else
// in the codebase. Until invited, they're a pure record with no login.
model Subcontractor {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  name           String
  type           String // formateur_externe | sous_traitant_pedagogique | prestataire_technique | autre
  // French OFPs contract both registered companies and individual
  // freelancers (auto-entrepreneurs) — the two carry different legal
  // mentions on a contract (a company has a raison sociale + forme
  // juridique; an individual just has their own SIRET, if any).
  isIndividual   Boolean      @default(false)
  legalForm      String? // company only — SARL, SAS, EI... blank/meaningless for an individual
  siret          String?
  address        String?
  contactEmail   String?
  contactPhone   String?
  qualifications String? // free text: diplomas, certifications, specialties

  contractStartDate       DateTime?
  contractEndDate         DateTime?
  qualificationExpiryDate DateTime? // e.g. a certification's expiry — distinct from the contract's own end date

  status String  @default("active") // active | expired | terminated
  notes  String?

  linkedUser   User?   @relation(fields: [linkedUserId], references: [id])
  linkedUserId String? @unique

  documents Document[]
  courses   Course[] @relation("CourseSubcontractors")

  createdAt DateTime @default(now())

  @@index([organizationId])
}

// One row per organization, created at signup. Spec §8's "14-day trial, no
// credit card required" means status starts at "trialing" with no Stripe
// customer/subscription id yet — those two fields, and the "active"/
// "past_due"/"canceled" statuses, only get populated once Stripe (or
// another processor) is actually wired in via /integrations and its
// webhook flips the status on payment events. Nothing in this codebase
// calls Stripe yet; this table exists so that wiring is "update a row",
// not "design a schema", when the time comes.
model Subscription {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @unique
  plan           String       // solo | team | growth
  status         String       @default("trialing") // trialing | active | past_due | canceled
  trialEndsAt    DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// The dashboard's "À faire" list is computed live from dossier/invoice/etc.
// state every page load — there's no underlying row to mark done, so
// "ignorer" needs its own record instead. Keyed by (kind, entityId), the
// same composite the widget already uses as its React key, and scoped to
// the whole org rather than per-user — simpler, and matches "this doesn't
// need chasing" being a shared team decision, not a personal one.
model DashboardTaskDismissal {
  id                String       @id @default(cuid())
  organization      Organization @relation(fields: [organizationId], references: [id])
  organizationId    String
  kind              String
  entityId          String
  dismissedByUserId String
  dismissedAt       DateTime     @default(now())

  @@unique([organizationId, kind, entityId])
  @@index([organizationId])
}

// A dated, frozen copy of the org chart (who was on the team, in which
// role, and which subcontractors were tracked, grouped exactly like the
// live "Organigramme" tab) — client feedback: the live view always
// reflects today's team, but a Qualiopi audit may ask "who was on staff
// as of [past date]", so staff can snapshot the current grouping on demand
// and pull it back up later instead of reconstructing it from memory.
model OrgChartSnapshot {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  createdByName  String
  data           Json

  @@index([organizationId, createdAt])
}

enum Role {
  ADMIN_OF
  ADMIN_MANAGER
  SALES
  TRAINER
  LEARNER
  DPO_EXTERNAL
}

model User {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  email          String       @unique
  name           String
  role           Role
  status         String       @default("active") // active | invited | disabled
  passwordHash   String? // null while status = "invited" — set once the member activates their account
  activationToken String?     @unique // set alongside status="invited"; consumed by /activation/[token]
  // "Mot de passe oublié" — set by /api/public/forgot-password, consumed by
  // /reinitialiser-mot-de-passe/[token]. Unlike activationToken this always
  // carries an expiry: an activation link is issued once by staff to a
  // known invitee, but a reset link is self-service and publicly requestable
  // by anyone typing an email address, so a stale unconsumed link staying
  // valid forever is a real risk, not just a tidiness concern.
  passwordResetToken          String?   @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt      DateTime     @default(now())
  // Sanitized HTML, set by the user themselves on /profil — auto-appended
  // to composed messages (client feedback: "la même signature qu'un mail
  // classique envoyé depuis sa boîte normale"). No auto-import from a
  // connected Gmail/IMAP mailbox: IMAP has no protocol-level concept of a
  // signature, and Gmail's lives behind a broader OAuth scope than this
  // app currently requests — this is the practical always-works version.
  emailSignature String?

  trainerSessions Session[]      @relation("SessionTrainer")
  learnerDossiers Dossier[]      @relation("DossierLearnerUser")
  referentHandicapForOrganizations Organization[] @relation("ReferentHandicap")
  responsibleForCourses Course[] @relation("CourseResponsibles")
  subcontractorRecord Subcontractor?
  documents Document[] @relation("UserDocuments")

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// CRM: contacts, companies, dossiers
// ---------------------------------------------------------------------------

model Company {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  siret          String?
  address        String?
  // Client feedback: when a training is company-funded (learnerCategory
  // employee/apprentice — see Dossier below), the OFP needs a named
  // point of contact at the company, not just its identity — stored
  // directly here rather than a separate contact-person table, same
  // pattern as Subcontractor's own contactEmail/contactPhone.
  responsableFirstName String?
  responsableLastName  String?
  responsableEmail     String?
  responsablePhone     String?

  contacts Contact[]

  @@index([organizationId])
}

// A Contact is a person (prospect, learner, HR contact, trainer contact...).
// IMPORTANT: emails are matched and stored against a Contact, never directly
// against a Dossier — see MailboxConnection / EmailMessage below and spec §5.11.
model Contact {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  firstName      String
  lastName       String
  email          String
  phone          String?
  company        Company?     @relation(fields: [companyId], references: [id])
  companyId      String?
  createdAt      DateTime     @default(now())
  // Client feedback: category (and company, via companyId above) should be
  // capturable the moment a new contact exists — even before any formation
  // enrollment — e.g. from the CRM "Nouveau prospect" form. Dossier has its
  // own learnerCategory (the one actually used for BPF reporting once
  // enrolled); this is only the carried-forward default a later enrollment
  // falls back to when the caller doesn't specify one explicitly — see
  // resolveContact in lib/enrollment.ts.
  defaultLearnerCategory String? // employee | jobseeker | individual | apprentice
  // Set automatically when one of their opportunities reaches PAID (client
  // feedback: a paid deal means the relationship is closed out, not still
  // an active prospect to keep chasing) — hides them from the default CRM
  // view the same way Course.archivedAt hides finished formations.
  archivedAt     DateTime?

  dossiers      Dossier[]
  emailMessages EmailMessage[]
  quotes        Quote[]
  invoices      Invoice[]
  opportunities Opportunity[]
  needsAssessmentRequests NeedsAssessmentRequest[]
  clientOutreaches ClientOutreach[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

// A specific training engagement for a Contact. A Contact can have many
// Dossiers over time (repeat clients) — this is why email auto-linking
// resolves to a Contact first, then suggests a Dossier (see spec §5.11).
model Dossier {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact      @relation(fields: [contactId], references: [id])
  contactId      String
  session        Session      @relation(fields: [sessionId], references: [id])
  sessionId      String
  learnerUser    User?        @relation("DossierLearnerUser", fields: [learnerUserId], references: [id])
  learnerUserId  String?      // set once the learner has portal access

  needsAssessmentDone Boolean  @default(false)
  contractSigned      Boolean  @default(false)
  convocationSent     Boolean  @default(false)
  evaluationHotDone   Boolean  @default(false)
  evaluationColdDone  Boolean  @default(false)

  legalBasis      String   @default("contract_performance")
  retentionUntil  DateTime?

  // Only meaningful for a ROLLING (self-paced, no fixed date) session: how
  // many days the learner has to finish once they start, and when they
  // actually did start. accessDurationDays is captured at enrollment;
  // firstAccessedAt is set the first time any LMS progress is recorded for
  // this dossier (see markDossierAccessed in lib/lms.ts) — that's the
  // "access" event the learner has no control over faking, unlike a
  // login timestamp which could predate ever opening a module.
  accessDurationDays Int?
  firstAccessedAt    DateTime?

  createdAt DateTime @default(now())

  // BPF §5.13 groups learner hours by legal status category. Client
  // feedback: this should be captured right when the learner is enrolled
  // (any entry point — course catalog, planning, course creation), not
  // only editable after the fact from the dossier — see lib/enrollment.ts.
  // Null = "non renseigné", a real, expected state until staff fills it in.
  learnerCategory String? // employee | jobseeker | individual | apprentice

  // Idempotency guard for the automation-rule cron (see
  // /api/cron/automation-rules): stamped the first time an automatic
  // reminder email for that trigger goes out for this dossier, so a rule
  // never re-sends the same nudge on a later run. convocation_missing needs
  // no field of its own — convocationSent (above) is already that guard.
  needsAssessmentAutoReminderSentAt DateTime?
  contractAutoReminderSentAt        DateTime?
  rollingDurationAutoReminderSentAt DateTime?
  satisfactionAutoReminderSentAt    DateTime?

  documents          Document[]
  qualiopiEvidence   QualiopiIndicatorEvidence[]
  elearningProgress  ElearningProgress[]
  quizAttempts       QuizAttempt[]
  virtualClassAttendances VirtualClassAttendance[]
  accommodationRequests AccommodationRequest[]
  complaints          Complaint[]
  invitations        SessionInvitation[]
  quotes             Quote[]
  invoices           Invoice[]
  clientOutreaches   ClientOutreach[]
  satisfactionSurveyResponses SatisfactionSurveyResponse[]

  @@index([organizationId])
  @@index([contactId])
}

// ---------------------------------------------------------------------------
// Training offer, sessions, planning
// ---------------------------------------------------------------------------

model Course {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  title          String
  description    String?
  // Archiving hides a course from the default catalog view without
  // deleting its history (sessions/dossiers/documents/certificates all
  // stay intact and queryable) — for offers no longer run but still
  // needed for compliance/audit lookback.
  archivedAt     DateTime?
  // Client feedback: a per-course document library should be able to pull
  // the formation's own reference info (title/duration/price) into any
  // document generated from it — see mergeTemplate.ts's course.* fields and
  // DocumentTemplate.courseId below. Nullable: most courses won't bother
  // filling these in until they actually attach a course-scoped template.
  durationHours  Int?
  priceCents     Int?

  documentTemplates DocumentTemplate[]
  sessions          Session[]
  elearningModules  ElearningModule[]
  opportunitiesOfInterest Opportunity[]
  qualityRisks      QualityRisk[]
  resultIndicators  ResultIndicator[]
  regulatoryWatchItems RegulatoryWatch[]
  // Who's accountable for this training — any team member, not just
  // trainers (a course can have an admin/coordinator responsible for it
  // without ever running a session themselves). Distinct from
  // Session.trainerId, which is who actually delivers one specific
  // session — a course can have several sessions with different trainers
  // while keeping the same responsible person(s) throughout.
  responsibleUsers  User[]            @relation("CourseResponsibles")
  // External providers (formateurs externes/prestataires) delivering this
  // training — distinct from responsibleUsers (internal staff accountable
  // for it) and Session.trainerId (an internal trainer delivering one
  // specific session). A course can lean on both internal and external
  // people at once.
  subcontractors    Subcontractor[]   @relation("CourseSubcontractors")
  automationRules   AutomationRule[]
  satisfactionSurveys SatisfactionSurvey[]

  @@index([organizationId])
}

// Client feedback: at course creation (or later), staff should be able to
// set up "relance" rules instead of relying only on the app's fixed global
// thresholds — e.g. "after N days, flag/relance if the recueil des besoins
// still isn't done." Scoped to a single course rather than global so
// different formations can have different follow-up cadences. `trigger` is
// a free string (one value supported today: needs_assessment_incomplete)
// rather than an enum, so new trigger kinds don't need a migration.
model AutomationRule {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  course         Course       @relation(fields: [courseId], references: [id])
  courseId       String

  trigger   String // see LEARNER... AUTOMATION_TRIGGER_VALUES in lib/automationRules.ts
  afterDays Int
  // Task-only by default (shows up in the dashboard's "À faire"); an OFP
  // opts a rule into also sending an automatic reminder email to the
  // learner, tracked separately per rule since not every OFP wants
  // unattended emails going out on their behalf. Written once at rule
  // creation (with [Prénom]/[Nom]/... merge tags — see
  // lib/automationRules.ts's fillMergeTags) and reused unedited for every
  // learner the rule fires for, rather than reopened per send.
  sendEmail    Boolean @default(false)
  emailSubject String?
  emailBody    String?
  active       Boolean @default(true)
  createdAt    DateTime @default(now())

  @@index([organizationId])
  @@index([courseId])
}

// Client feedback: "évaluation à chaud/à froid" needs to be a real
// questionnaire (sent, answered, stored) rather than a checkbox staff
// tick by hand — mirrors direct competitors (Digiforma/Dendreo), where a
// satisfaction survey is a first-class product, not a manual step. One
// survey per (course, kind) — kind is "hot" (sent at session end) or
// "cold" (sent per the existing satisfaction_not_collected AutomationRule
// delay) — questions are fully custom per course, same JSON-options
// pattern as QuizQuestion so a single form renderer handles both.
model SatisfactionSurvey {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  course         Course       @relation(fields: [courseId], references: [id])
  courseId       String
  kind           String // hot | cold
  questions      SatisfactionSurveyQuestion[]
  responses      SatisfactionSurveyResponse[]
  createdAt      DateTime     @default(now())

  @@unique([courseId, kind])
  @@index([organizationId])
}

model SatisfactionSurveyQuestion {
  id       String             @id @default(cuid())
  survey   SatisfactionSurvey @relation(fields: [surveyId], references: [id])
  surveyId String
  order    Int
  // rating (1-5) | single_choice | multiple_choice | text
  type     String
  prompt   String
  // [{ id, text }] for single_choice/multiple_choice — no "correct" flag,
  // unlike QuizQuestion, since satisfaction has no right answer.
  options  Json?

  @@index([surveyId])
}

model SatisfactionSurveyResponse {
  id             String             @id @default(cuid())
  organization   Organization       @relation(fields: [organizationId], references: [id])
  organizationId String
  survey         SatisfactionSurvey @relation(fields: [surveyId], references: [id])
  surveyId       String
  dossier        Dossier            @relation(fields: [dossierId], references: [id])
  dossierId      String
  // Public-link access, same pattern as NeedsAssessmentRequest — works
  // whether the learner has a mon-espace account or not (client feedback:
  // must work both ways).
  token       String    @unique
  status      String    @default("sent") // sent | completed
  answers     Json? // { [questionId]: string | string[] }
  sentAt      DateTime  @default(now())
  completedAt DateTime?

  @@unique([surveyId, dossierId])
  @@index([organizationId])
  @@index([dossierId])
}

enum SessionFormat {
  IN_PERSON
  REMOTE
  HYBRID
}

// DRAFT sessions are still being put together (dates/trainer/roster can
// change freely); VALIDATED is the point at which convocations should go
// out. CANCELLED is a manual dead-end (client feedback: staff need to call
// off a session — trainer unavailable, too few sign-ups — without deleting
// it or pretending it's still live). Archival is separate from status —
// see Session.archivedAt below — since a cancelled OR completed session can
// each independently be tidied out of the active Planning views.
enum SessionStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

// Some OFPs run cohort training on a fixed calendar (FIXED_DATE — the
// existing model: a real start/end, a room or meeting link, a capacity).
// Others sell self-paced e-learning that's simply always available
// (ROLLING) — a learner's clock starts the moment *they* first log in, not
// on a shared date. Session.startsAt/endsAt stay non-null either way (kept
// simple rather than making half the schema nullable) — for ROLLING
// sessions they're set to a wide-open placeholder window at creation and
// the UI just doesn't show them; what actually matters for a rolling
// learner is Dossier.accessDurationDays/firstAccessedAt below.
enum SessionMode {
  FIXED_DATE
  ROLLING
}

model Session {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  course         Course        @relation(fields: [courseId], references: [id])
  courseId       String
  mode           SessionMode   @default(FIXED_DATE)
  trainer        User?         @relation("SessionTrainer", fields: [trainerId], references: [id])
  trainerId      String?
  startsAt       DateTime
  endsAt         DateTime
  format         SessionFormat
  status         SessionStatus @default(DRAFT)
  location       String?       // room name/address (IN_PERSON, HYBRID) or existing video link (REMOTE)
  capacity       Int
  // Auto-generated once, on first invitation send for a REMOTE/HYBRID
  // session — see /api/planning/sessions/[id]/invitations. Uses a public
  // Jitsi Meet room (no account/API key required) as the default video
  // provider since the spec doesn't mandate one; swap for a real
  // Zoom/Meet/Teams integration if the client picks a provider later.
  meetingLink    String?
  // Client feedback: past sessions used to just fall out of the "Liste" view
  // once endsAt passed, with no way to browse them again. This is a manual
  // toggle (staff-driven, not date-driven) so a cancelled-but-future session
  // can be tidied away too, and so "Archives" is an explicit place to look
  // rather than sessions silently vanishing.
  archivedAt     DateTime?

  dossiers    Dossier[]
  invitations SessionInvitation[]
  attendances VirtualClassAttendance[]

  @@index([organizationId])
}

// Electronic attendance for a REMOTE/HYBRID session, driven by the
// learner's browser actually being on the Conforma-hosted meeting room page
// (see /mon-espace/salle/[dossierId] and its heartbeat ping), not a staff
// checkbox ticked from memory after the fact. durationSeconds accumulates
// across reconnects — one row per (session, dossier) rather than one row
// per connection interval, since "how long were they actually present in
// total" is what an attendance certificate needs, not a raw connection log.
// Known honesty limit: this measures browser-tab presence on the room page,
// not camera/mic/audio-on state — there's no way to see that from an
// embedded, cross-origin Jitsi iframe without a real conferencing API.
model VirtualClassAttendance {
  id              String    @id @default(cuid())
  session         Session   @relation(fields: [sessionId], references: [id])
  sessionId       String
  dossier         Dossier   @relation(fields: [dossierId], references: [id])
  dossierId       String
  joinedAt        DateTime
  lastPingAt      DateTime
  leftAt          DateTime?
  durationSeconds Int       @default(0)

  @@unique([sessionId, dossierId])
  @@index([sessionId])
  @@index([dossierId])
}

// A session invitation is what gets sent to one enrolled learner (Dossier)
// for a Session: a video link (REMOTE/HYBRID, auto-generated once per
// session — see Session.meetingLink) and/or a venue map link derived from
// Session.location (IN_PERSON/HYBRID, computed on the fly, not stored).
// Sending one also flips Dossier.needsAssessmentDone's sibling
// `convocationSent` — this *is* the "convocation" step from the dossier
// journey checklist, not a separate concept.
model SessionInvitation {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  session        Session      @relation(fields: [sessionId], references: [id])
  sessionId      String
  dossier        Dossier      @relation(fields: [dossierId], references: [id])
  dossierId      String
  // Denormalized snapshot rather than a User relation — this is an audit
  // trail entry, not something that needs to stay live-joined to the user
  // (and it should still read sensibly if that user is later deactivated).
  sentByUserId   String
  sentByName     String
  sentAt         DateTime     @default(now())

  documents SessionInvitationDocument[]

  @@index([organizationId])
  @@index([sessionId])
  @@index([dossierId])
}

model SessionInvitationDocument {
  id           String            @id @default(cuid())
  invitation   SessionInvitation @relation(fields: [invitationId], references: [id])
  invitationId String
  document     Document          @relation(fields: [documentId], references: [id])
  documentId   String

  @@unique([invitationId, documentId])
}

// ---------------------------------------------------------------------------
// Commercial: quotes, invoices
// ---------------------------------------------------------------------------

enum DocStatus {
  DRAFT
  SENT
  SIGNED
  PAID
  OVERDUE
}

enum PipelineStage {
  PROSPECT
  QUOTE_SENT
  CONTRACT_SIGNED
  SESSION_SCHEDULED
  TO_INVOICE
  INVOICED
  PAID
}

model Opportunity {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact       @relation(fields: [contactId], references: [id])
  contactId      String
  label          String
  amountCents    Int?
  stage          PipelineStage @default(PROSPECT)
  createdAt      DateTime      @default(now())

  needsAssessmentRequests NeedsAssessmentRequest[]
  // Sales rep who created it — spec §2 scopes SALES to "their own prospects";
  // null for opportunities created before this field existed or by non-Sales
  // roles who don't need the restriction.
  ownerId        String?
  // Course the prospect is interested in — powers the Planning autosuggest
  // (match a session's course against CONTRACT_SIGNED opportunities to
  // propose who to enrol). Optional: pre-existing opportunities and ones
  // created without picking a course just won't be suggested anywhere.
  courseOfInterest   Course? @relation(fields: [courseOfInterestId], references: [id])
  courseOfInterestId String?

  @@index([organizationId])
  @@index([stage])
}

model Quote {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact      @relation(fields: [contactId], references: [id])
  contactId      String
  dossier        Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId      String?
  reference      String
  amountCents    Int
  status         DocStatus    @default(DRAFT)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model Invoice {
  id                  String       @id @default(cuid())
  organization        Organization @relation(fields: [organizationId], references: [id])
  organizationId       String
  contact              Contact      @relation(fields: [contactId], references: [id])
  contactId            String
  dossier              Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId            String?
  reference            String
  amountCents          Int
  status               DocStatus    @default(DRAFT)
  // The invoice is NOT itself the compliant e-invoice — transmission via an
  // accredited platform is delegated per spec §5.3 / §7.2. This field just
  // records which provider (if any) handled the compliant transmission.
  einvoicingProvider   String?      // "pennylane" | "sellsy" | "ppf" | null
  // BPF §5.13 needs revenue broken down by funding origin.
  fundingOrigin        String?      // company | opco | public | individual
  createdAt            DateTime     @default(now())

  payments Payment[]

  @@index([organizationId])
}

// A single installment against an Invoice — an invoice can be settled in
// several partial payments (spec request: "suivi des paiements en
// plusieurs fois") rather than only ever being marked fully PAID at once.
// Recording one that brings the running total to/past Invoice.amountCents
// auto-flips the invoice to PAID (see /api/facturation/invoices/[id]/payments);
// a partial one just shows up as progress toward the total, status
// unchanged. `method` is free text (virement, carte, chèque, espèces,
// Stripe...) rather than an enum since real payment methods vary more than
// this scaffold needs to model rigidly.
model Payment {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  invoiceId      String
  amountCents    Int
  paidAt         DateTime     @default(now())
  method         String?
  recordedByUserId String?
  recordedByName   String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Documents (generated or uploaded)
// ---------------------------------------------------------------------------

model Document {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  dossier        Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId      String?
  subcontractor  Subcontractor? @relation(fields: [subcontractorId], references: [id])
  subcontractorId String?
  // A staff/team member's own document (CV, diplôme...) — same Document
  // model as dossier/subcontractor documents, just a third optional owner.
  user           User?          @relation("UserDocuments", fields: [userId], references: [id])
  userId         String?
  title          String
  // Uploaded/linked documents carry a fileUrl. Documents generated by the
  // toolkit's merge-field engine (see /api/documents/generate) carry
  // bodyText instead — the merged text itself, since there's no file
  // storage to put a real file into yet. One of the two is always set.
  fileUrl        String?
  bodyText       String?
  templateOrigin String?      // which toolkit template this was generated from, if any
  // Denormalized from DocumentTemplate.category at generation/upload time —
  // a Document needs its own copy since the source template can be edited
  // or deleted later, and a manually-linked document (no template at all)
  // still needs a category to show up correctly in "Mes documents"
  // (src/app/(app)/documents/page.tsx). Defaults to "other" so existing
  // rows and manual adds without a picked category still file predictably.
  category       String       @default("other")
  // Who sent it — nullable since older rows (uploads via
  // AddDossierDocumentForm, LMS certificates, /api/documents/generate) predate
  // this; also who a completed signature's staff notification email goes to.
  sentByUserId   String?
  sentByName     String?
  // "none" | "pending" | "signed" — set at send time (SendDocumentDialog's
  // "Demander une signature électronique" checkbox), flipped to "signed" by
  // the learner's mon-espace sign action. Deliberately NOT wired to a real
  // e-signature provider yet (Yousign client exists in lib/yousign.ts,
  // integration explicitly deferred by the client) — this is the status/UI
  // half of the workflow, ready to swap the stub sign action for a real
  // Yousign signature-request flow later without changing the data model.
  signatureStatus String      @default("none")
  signedAt       DateTime?
  createdAt      DateTime     @default(now())
  // Client feedback: a document needed for a Qualiopi audit shouldn't be
  // permanently deleted just because it's no longer "current" — archiving
  // keeps the row (and its file) around, out of the active list, still
  // retrievable later. Deletion stays available separately for genuine
  // mistakes/duplicates.
  archivedAt     DateTime?

  invitationLinks SessionInvitationDocument[]

  @@index([organizationId])
}

// The reusable document library (spec §5.8's "legal document toolkit" —
// scoped down here to a plain editable-text library, not the dynamic
// merge-field personalization engine the full toolkit describes; that
// remains a separate, bigger build). `organizationId: null` marks a
// starter template Conforma ships to every org; an org "adapts" one by
// creating its own copy (`forkedFromId` points back at the original) which
// they can then freely edit — the starter stays untouched as a reference.
model DocumentTemplate {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  category       String        // needs_assessment | convention | convocation | eval_hot | eval_cold | cgv | internal_rules | other
  title          String
  bodyText       String
  forkedFromId   String?
  createdAt      DateTime      @default(now())
  // Client feedback: a template scoped to one formation (vs. the general
  // library) — its documents should auto-pull that course's own info
  // (title/duration/price) via mergeTemplate.ts's course.* fields. Null
  // means "general" — usable/generated for any dossier regardless of course.
  course         Course?       @relation(fields: [courseId], references: [id])
  courseId       String?

  @@index([organizationId])
  @@index([courseId])
}

// The "send the needs assessment to a prospect" tool from the CRM: a
// snapshot of the template text at send time (so a later library edit
// doesn't retroactively change a request already sent out) plus a token
// for the unauthenticated public fill-in page. Deliberately scoped to just
// this one document category rather than a generic "any template, any
// recipient" engine — that's what was actually asked for; the library
// itself (DocumentTemplate above) still covers every other document type
// for internal use/download.
model NeedsAssessmentRequest {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact       @relation(fields: [contactId], references: [id])
  contactId      String
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id])
  opportunityId  String?
  token          String        @unique
  templateBody   String
  responseText   String?
  status         String        @default("sent") // sent | completed
  sentByUserId   String
  sentByName     String
  sentAt         DateTime      @default(now())
  completedAt    DateTime?

  @@index([organizationId])
  @@index([contactId])
}

// ---------------------------------------------------------------------------
// GDPR module
// ---------------------------------------------------------------------------

model ProcessingActivity {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  legalBasis     String
  retentionPeriod String
  riskFlag       String       @default("ok") // ok | to_review
  createdAt      DateTime     @default(now())

  dpiaRecords DPIARecord[]

  @@index([organizationId])
}

model SubProcessor {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  role           String
  location       String
  dpaStatus      String       @default("pending") // pending | signed
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model DPIARecord {
  id                    String              @id @default(cuid())
  organization          Organization        @relation(fields: [organizationId], references: [id])
  organizationId        String
  processingActivity    ProcessingActivity  @relation(fields: [processingActivityId], references: [id])
  processingActivityId  String
  subject               String
  riskLevel             String              // low | moderate | high
  status                String              @default("required") // required | in_progress | validated | not_required
  createdAt             DateTime            @default(now())

  @@index([organizationId])
}

model RightsRequest {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  requestType    String   // access | erasure | portability | rectification
  personLabel    String
  deadline       DateTime
  status         String   @default("open") // open | in_progress | closed
  createdAt      DateTime @default(now())
  // Plain id + denormalized name, no formal relation — same pattern as
  // EmailMessage.assignedToUserId/assignedToName elsewhere in this schema.
  // Client feedback: a request just sat there with no owner; this is who's
  // actually working it.
  assignedToUserId String?
  assignedToName   String?
  // Set when a learner files this themselves via the unified support dialog
  // (mon-espace's "Aide & demandes") instead of staff creating it manually
  // from a dossier — null for the latter case.
  submittedByUserId String?
  details           String?

  @@index([organizationId])
}

// GDPR art. 33/34 — the register of security incidents/data breaches this
// module was missing entirely: DPIA and the processing register cover
// planned risk, this covers what actually happened. notifiedAuthorityAt /
// notifiedSubjectsAt track the two distinct 72h-window obligations (CNIL,
// then affected individuals if the breach is high-risk) separately, since
// one can legitimately happen without the other (low-risk breaches don't
// require notifying the people affected).
model DataBreach {
  id                  String       @id @default(cuid())
  organization        Organization @relation(fields: [organizationId], references: [id])
  organizationId      String
  title               String
  description         String
  discoveredAt        DateTime
  affectedDataTypes   String       // free text — which personal data categories were exposed
  affectedPeopleCount Int?
  severity            String       @default("moderate") // low | moderate | high
  status              String       @default("investigating") // investigating | contained | closed
  notifiedAuthorityAt DateTime?    // CNIL notification, due within 72h of discovery if required
  notifiedSubjectsAt  DateTime?    // affected individuals, if high risk (art. 34)
  remediation         String?
  createdByName       String
  createdAt           DateTime     @default(now())

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Qualiopi module
// ---------------------------------------------------------------------------

// The RNQ isn't a single fixed list — it's republished by arrêté from time
// to time (see the "réforme référentiel" article on /actualites), with a
// status lifecycle (projet → publié → applicable → archivé) and its own
// indicator set per version. Each organization tracks which version it's
// currently auditing itself against (Organization.activeReferentielVersion)
// so switching to a new version — or previewing a still-draft one ahead of
// its application date — never silently rewrites another org's checklist.
model QualiopiReferentielVersion {
  id             String   @id @default(cuid())
  label          String   // e.g. "RNQ 2022 (en vigueur)", "RNQ — Réforme 2026 (projet)"
  status         String   @default("projet") // projet | publie | applicable | archive
  publishedAt    DateTime?
  applicableFrom DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  indicators    QualiopiIndicator[]
  organizations Organization[] @relation("ActiveReferentiel")
}

// Reference data for a given RNQ version — shared across every organization
// that has that version active (it's the same official criteria/indicators
// for everyone on that version), not tenant-scoped. Spec §7.3 asks that
// this be data-driven rather than hardcoded in the UI so it can be updated
// as the RNQ changes; this table is that. Labels here are working summaries
// for the scaffold — verify wording against the official France Compétences
// referential text before relying on them for an actual audit.
model QualiopiIndicator {
  id              String                     @id @default(cuid())
  version         QualiopiReferentielVersion @relation(fields: [versionId], references: [id])
  versionId       String
  number          Int    // 1–32 within its version
  criterionNumber Int    // 1–7
  label           String

  @@unique([versionId, number])
  @@index([versionId])
}

model AuditChecklistItem {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  indicatorNumber Int
  gathered       Boolean      @default(false)

  // AI-generated, org-specific explanation of what this indicator actually
  // requires and what evidence to gather — "voir mon résumé personnalisé"
  // on the Préparation audit tab. Cached here (same per-org+indicator
  // granularity this model already has) so it's generated once, not on
  // every page load; personalizedSummaryAt lets the UI offer "Régénérer"
  // without needing a separate flag for "has one ever been generated."
  personalizedSummary   String?
  personalizedSummaryAt DateTime?

  @@unique([organizationId, indicatorNumber])
  @@index([organizationId])
}

model QualiopiIndicatorEvidence {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  dossier        Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId      String?
  criterionNumber Int         // 1–7
  indicatorNumber Int         // 1–32
  evidenceNote    String?

  @@index([organizationId])
}

model NonConformity {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  type           String       // complaint | non_conformity | suggestion
  subject        String
  origin         String
  status         String       @default("open") // open | in_progress | resolved
  dueDate        DateTime?

  qualityRisks   QualityRisk[]

  @@index([organizationId])
}

// Qualiopi indicator 28 (dispositif d'amélioration continue) asks for more
// than a complaint log — a real risk register with likelihood/severity,
// an owner, and a preventive/corrective plan. Deliberately a separate model
// from NonConformity rather than extending it: a complaint is a raw input
// ("someone reported X"), a risk is an analysis of it ("here's what could
// go wrong, how likely, how bad, what we're doing about it") — not every
// complaint becomes a risk, and a risk can originate from more than a
// complaint (a bad result, an audit finding, regulatory watch). The link is
// optional and one-directional (sourceNonConformityId), so promoting a
// complaint to a risk never mutates the original complaint record.
model QualityRisk {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  course         Course?       @relation(fields: [courseId], references: [id])
  courseId       String?
  sourceNonConformity   NonConformity? @relation(fields: [sourceNonConformityId], references: [id])
  sourceNonConformityId String?

  risk              String
  origin            String   // reclamation | resultat | audit | veille | autre
  probability       String   // faible | moyenne | elevee
  severity          String   // faible | moyenne | elevee
  ownerUserId       String?
  ownerName         String?
  preventiveMeasure String?
  correctiveAction  String?
  dueDate           DateTime?
  evidenceNote      String?
  status            String   @default("identifie") // identifie | en_cours | maitrise | clos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([courseId])
}

// Qualiopi indicator 2 asks for published results indicators with an
// explicit calculation method, not just a headline number — an auditor (or
// a prospect) needs to see the definition, the formula, the period, and the
// population it was computed over. "computedFrom" records which real query
// produced computedValue (see src/lib/resultIndicators.ts) so a number is
// never just typed in and passed off as measured; "manual" is the one
// exception, for indicators this scaffold has no underlying data source
// for yet (e.g. a real satisfaction survey), and is flagged as such in the
// UI rather than presented the same way as a computed one.
model ResultIndicator {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  course         Course?      @relation(fields: [courseId], references: [id])
  courseId       String?

  label          String
  definition     String
  formula        String
  computedFrom   String   // elearning_completion | hot_evaluation_rate | manual
  periodStart    DateTime
  periodEnd      DateTime
  totalPopulation Int
  respondents     Int
  exclusions      Int      @default(0)
  computedValue   Float?   // percentage, 0–100

  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([organizationId])
  @@index([courseId])
}

// ---------------------------------------------------------------------------
// LMS
// ---------------------------------------------------------------------------

model ElearningModule {
  id          String  @id @default(cuid())
  course      Course  @relation(fields: [courseId], references: [id])
  courseId    String
  title       String
  description String?
  // "video" | "document" | "quiz" — drives which player the learner portal
  // renders and how progress is computed (playback position, a manual
  // "marquer comme lu", or a graded attempt). Free-text rather than an enum:
  // cheap to extend later (audio, scorm package, ...) without a migration.
  type        String  @default("video")
  // Real uploaded content (Vercel Blob — see src/lib/storage.ts), not a
  // pasted external link like Document.fileUrl elsewhere in this app.
  // Unused for type "quiz" — that content lives in the linked Quiz instead.
  fileUrl      String?
  fileName     String?
  fileSizeBytes Int?
  order       Int     @default(0)
  createdAt   DateTime @default(now())

  progress ElearningProgress[]
  quiz     Quiz?
  versions ElearningModuleVersion[]
}

// A history entry for a module's *previous* file, written right before it
// gets replaced (see POST /api/lms/modules/[id]/replace-file) — the current
// file always lives on ElearningModule itself, this table only holds what
// used to be there. Replacing a video a learner already has progress
// against would silently invalidate that progress (their recorded percent
// refers to a position in the old file, which may not even exist in the
// new one) — the replace endpoint requires an explicit confirmation in
// that case rather than swapping the file out from under them unannounced.
model ElearningModuleVersion {
  id            String          @id @default(cuid())
  module        ElearningModule @relation(fields: [moduleId], references: [id])
  moduleId      String
  fileUrl       String?
  fileName      String?
  fileSizeBytes Int?
  replacedAt     DateTime @default(now())
  replacedByName String

  @@index([moduleId])
}

// One quiz per module (type "quiz") — mirrors how a video/document module
// has exactly one piece of content. Passing a quiz completes the module the
// same way finishing a video does: ElearningProgress.percentComplete hits
// 100 and the existing auto-unlock-next-module logic in
// unlockNextModuleIfNeeded (src/lib/lms.ts) fires, same as any other module
// type — a quiz isn't a special case downstream of "did they finish this."
model Quiz {
  id              String          @id @default(cuid())
  module          ElearningModule @relation(fields: [moduleId], references: [id])
  moduleId        String          @unique
  minScorePercent Int             @default(70)
  maxAttempts     Int?            // null = unlimited
  questions       QuizQuestion[]
  attempts        QuizAttempt[]
  createdAt       DateTime        @default(now())
}

model QuizQuestion {
  id       String @id @default(cuid())
  quiz     Quiz   @relation(fields: [quizId], references: [id])
  quizId   String
  order    Int
  // single_choice | multiple_choice | true_false | short_answer
  type     String
  prompt   String
  // [{ id, text, correct }] for single_choice/multiple_choice/true_false —
  // the correct flags live here, not just in the answer-checking code, so
  // "what's the right answer" is inspectable/editable data, not logic.
  options  Json?
  // short_answer only — graded by exact match (trimmed, case-insensitive),
  // not semantic comparison; a deliberate scaffold limitation, not hidden.
  correctAnswerText String?

  @@index([quizId])
}

model QuizAttempt {
  id           String   @id @default(cuid())
  quiz         Quiz     @relation(fields: [quizId], references: [id])
  quizId       String
  dossier      Dossier  @relation(fields: [dossierId], references: [id])
  dossierId    String
  answers      Json     // { [questionId]: string | string[] }
  scorePercent Int
  passed       Boolean
  submittedAt  DateTime @default(now())

  @@index([quizId])
  @@index([dossierId])
}

model ElearningProgress {
  id                 String          @id @default(cuid())
  dossier            Dossier         @relation(fields: [dossierId], references: [id])
  dossierId          String
  module             ElearningModule @relation(fields: [moduleId], references: [id])
  moduleId           String
  percentComplete    Int             @default(0)
  // Raw playback position, separate from percentComplete — percent is
  // "furthest point ever reached" (never regresses, see the progress
  // route), but resuming should pick up from wherever the learner actually
  // paused, which can be earlier than their furthest point if they went
  // back to re-watch something. Video only; documents have no position.
  lastPositionSeconds Int?
  lastEventAt        DateTime?       // last tracked login/lesson/quiz event —
                                       // feeds Qualiopi evidence, see spec §5.12
  // This row IS the assignment record — a learner only sees a module once
  // one exists for their dossier (see /mon-espace). Created exclusively by
  // staff (see /api/lms/modules/[id]/assign); a learner can update their
  // own row's percentComplete but can no longer create one for themselves,
  // closing the implicit self-assignment gap the previous version had.
  assignedAt         DateTime        @default(now())
  assignedByUserId   String?
  assignedByName     String?

  @@unique([dossierId, moduleId])
}

// ---------------------------------------------------------------------------
// Mailbox integration & inbox triage (spec §5.11)
// ---------------------------------------------------------------------------

model MailboxConnection {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  provider       String       // "gmail" | "outlook" | "imap"
  accountEmail   String
  // OAuth tokens (gmail/outlook) encrypted at rest via src/lib/crypto.ts
  // (AES-256-GCM) — see TOKEN_ENCRYPTION_KEY. accessToken is refreshed on
  // every sync/send call rather than tracked for expiry, so its stored
  // value is mostly for debugging; refreshToken is what actually matters
  // long-term. Both are null for provider="imap".
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  // IMAP/SMTP (any other provider — OVH, Ionos, Zoho...) — same encryption,
  // a single password used for both since most hosts share credentials
  // across the two protocols. All null for gmail/outlook.
  passwordEncrypted String?
  imapHost          String?
  imapPort           Int?
  smtpHost          String?
  smtpPort           Int?
  connectedAt    DateTime     @default(now())
  lastSyncedAt   DateTime?

  emailMessages  EmailMessage[]

  // An org can connect several mailboxes (several Gmail accounts, an IMAP
  // account, etc.) — uniqueness is per actual account, not per provider.
  @@unique([organizationId, provider, accountEmail])
  @@index([organizationId])
}

model EmailMessage {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact?     @relation(fields: [contactId], references: [id])
  contactId      String?      // null = unmatched, goes to inbox triage
  suggestedDossierId String?  // set only when a reliable signal was found (thread or reference match)
  matchBasis     String?      // "thread" | "reference" | null
  fromAddress    String
  fromName       String?      // display name from the "From" header, when present — feeds the "Nouveau prospect" pre-fill, not an AI guess
  subject        String
  snippet        String
  body           String?      // full content — snippet stays a short preview for list views
  externalId     String?      @unique // provider message id (e.g. Gmail's id) — dedupes repeated syncs; null for locally-composed replies and seed/demo rows
  externalThreadId String?    // Gmail threadId — lets a real reply land in the same Gmail conversation instead of starting a new one
  receivedAt     DateTime
  direction      String       // "in" | "out"

  // Which connected mailbox this came from — null for seed/demo rows and
  // locally-composed replies that predate multi-mailbox support. Lets
  // /inbox filter to one mailbox and lets disconnecting one mailbox only
  // clear messages that actually came from it.
  mailboxConnection   MailboxConnection? @relation(fields: [mailboxConnectionId], references: [id])
  mailboxConnectionId String?

  // Team triage: who on the team is handling this message. Denormalized
  // name alongside the id so list views don't need an extra join, same
  // pattern as sentByUserId/sentByName elsewhere in this schema.
  assignedToUserId String?
  assignedToName   String?

  // Reply threading — a reply is its own "out" EmailMessage row pointing
  // back at the message it answers. No real delivery happens (no mailbox
  // is actually connected yet), so this just records the reply was
  // composed and against which thread.
  replyTo        EmailMessage?  @relation("EmailThread", fields: [inReplyToId], references: [id])
  inReplyToId    String?
  replies        EmailMessage[] @relation("EmailThread")

  // AI classification for the RGPD register (spec: catch exercise-of-rights
  // requests — access/erasure/portability/rectification — buried in the
  // inbox before their legal 1-month deadline runs out, rather than relying
  // on a human to notice one among newsletters and prospect emails).
  // rgpdClassifiedAt is set the first time classification runs so a synced
  // message is never re-classified (cost control); rgpdSuggestedType holds
  // the open suggestion and is cleared once staff confirms or dismisses it
  // — same "AI suggests, human decides" shape as suggestedDossierId above,
  // never auto-creates the actual RightsRequest record on its own.
  rgpdClassifiedAt  DateTime?
  rgpdSuggestedType String?   // access | erasure | portability | rectification | null
  rgpdReasoning     String?

  @@index([organizationId])
  @@index([contactId])
}

// Tracks a client-record-initiated send of a document/step that isn't
// already covered by a dedicated flow — NeedsAssessmentRequest handles the
// positioning test (with its own public fill-in page), SessionInvitation
// handles the convocation (with its meeting/map links). This is the same
// "sent, waiting on the other side" bookkeeping for the two remaining
// steps a staff member can trigger from a client record: the contract and
// platform access. No real email delivery — same constraint as everywhere
// else in this scaffold — but a real, queryable record of what was sent,
// when, and whether it was ever acted on, which is what "relances" needs.
model ClientOutreach {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  contact        Contact      @relation(fields: [contactId], references: [id])
  contactId      String
  dossier        Dossier?     @relation(fields: [dossierId], references: [id])
  dossierId      String?
  type           String       // "contract" | "platform_access"
  status         String       @default("sent") // sent | acknowledged
  sentByUserId   String
  sentByName     String
  sentAt         DateTime     @default(now())
  acknowledgedAt DateTime?

  @@index([organizationId])
  @@index([contactId])
  @@index([dossierId])
}

// ---------------------------------------------------------------------------
// Third-party integration credentials (spec §3)
// ---------------------------------------------------------------------------

// Storage only — no feature in this scaffold actually calls out to any of
// these providers yet (see README). Plaintext here is NOT production-ready;
// spec §7.1 requires encryption at rest for exactly this kind of secret —
// same flag as MailboxConnection's token fields above. Wire real encryption
// (or a proper secrets manager) before this holds a real API key.
model IntegrationCredential {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  provider       String       // brevo | yousign | pennylane | sellsy | google_oauth | microsoft_oauth
  apiKey         String?
  clientId       String?
  clientSecret   String?
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Public marketing site content — NOT tenant-scoped: this is Conforma's own
// editorial content and visitor list, not an OFP's data.
// ---------------------------------------------------------------------------

model NewsArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String   // qualiopi | rgpd | reglementation | produit
  excerpt     String
  body        String
  publishedAt DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}
